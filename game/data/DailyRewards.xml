<?xml version="1.0" encoding="UTF-8"?>
<!-- 
	Daily Rewards Configuration
	
	Attributes:
	- checkType: How to track players (ACCOUNT, CHARACTER, IP)
	- resetHour: Hour of day when rewards reset (0-23)
	- resetMinute: Minute when rewards reset (0-59)
	
	Each <day> element represents rewards for that day in the cycle.
	When a player reaches the last day, they cycle back to day 1.
	
	Reward attributes:
	- itemId: The ID of the item to give
	- count: How many of the item to give
	
	Optional day attributes:
	- icon: Custom icon to display (e.g., "icon.etc_adena_i00")
-->
